# ================================
# TOEIC Learning Web Application
# ================================

# === General ===
NODE_ENV=production
APP_URL=http://localhost
API_URL=http://localhost/api

# === PostgreSQL ===
POSTGRES_USER=toeic_user
POSTGRES_PASSWORD=change_me_123
POSTGRES_DB=toeic_learning
DATABASE_URL=postgresql://toeic_user:change_me_123@postgres:5432/toeic_learning

# === Redis ===
REDIS_URL=redis://redis:6379

# === Authentication ===
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_must_be_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost

# === MinIO (File Storage) ===
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=toeic-assets
